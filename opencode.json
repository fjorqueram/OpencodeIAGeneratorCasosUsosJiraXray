{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "agent": {
    "gentle-orchestrator": {
      "description": "Gentle AI SDD Orchestrator - coordinates sub-agents, never does work inline",
      "mode": "primary",
      "prompt": "{file:/home/fjorquera/.config/opencode/AGENTS.md}",
      "permission": {
        "task": {
          "*": "deny",
          "sdd-apply": "allow",
          "sdd-archive": "allow",
          "sdd-design": "allow",
          "sdd-explore": "allow",
          "sdd-init": "allow",
          "sdd-onboard": "allow",
          "sdd-propose": "allow",
          "sdd-spec": "allow",
          "sdd-tasks": "allow",
          "sdd-verify": "allow",
          "qa-xray-certification": "allow"
        }
      },
      "tools": {
        "bash": true,
        "delegate": true,
        "delegation_list": true,
        "delegation_read": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
