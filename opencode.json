  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "type": "local",
      "command": ["engram", "mcp", "--tools=agent"],
      "enabled": true
    },
    "jira": {
      "enabled": true,
      "timeout": 12000,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "github": {
      "type": "local",
      "command": ["/usr/local/bin/github-mcp-server", "stdio"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN"
      },
      "enabled": true
    },
    "postman": {
      "type": "local",
      "command": ["npx", "-y", "@postman/postman-mcp-server@latest", "--full"],
      "env": {
        "POSTMAN_API_KEY": "$POSTMAN_API_KEY"
      },
      "enabled": true
    },
    "xray": {
      "type": "local",
      "command": ["node", "/home/fjorquera/.config/opencode/mcp-xray/dist/index.js"],
      "env": {
        "XRAY_CLIENT_ID": "$XRAY_CLIENT_ID",
        "XRAY_CLIENT_SECRET": "$XRAY_CLIENT_SECRET",
        "JIRA_URL": "https://imed.atlassian.net",
        "JIRA_EMAIL": "$JIRA_EMAIL",
        "JIRA_API_TOKEN": "$JIRA_API_TOKEN"
      },
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  }
}
